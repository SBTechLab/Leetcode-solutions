class Solution {
    public int[] singleNumber(int[] nums) {
        
        int xor =0;
        for(int num:nums){   //start xor with 0 and go with all numbers 
            xor ^= num;
        }

        int differ = xor  & - xor;

        int a = 0;
        int b = 0;

        for(int num: nums){
            if ((num & differ) == 0){ 
                a ^= num;

            }else{
                b ^= num;
            }
        }
      
      return new int[]{a,b};


    }
}
